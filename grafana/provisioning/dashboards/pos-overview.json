{
  "title": "POS Overview",
  "uid": "pos-overview",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "America/La_Paz",
  "panels": [
    {
      "id": 1,
      "title": "Pedidos por minuto",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
          "expr": "rate(pos_orders_created_total[5m]) * 60",
          "legendFormat": "{{ payment_method }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "Ingresos acumulados (Bs)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
          "expr": "increase(pos_orders_revenue_bs_total[1h])",
          "legendFormat": "Bs/hora"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyBOB",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "title": "Sesiones de caja activas",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
          "expr": "pos_cash_sessions_opened_total - pos_cash_sessions_closed_total",
          "legendFormat": "Abiertas"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Total pedidos (3 horas)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
          "expr": "increase(pos_orders_created_total[3h])",
          "legendFormat": "Pedidos"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "title": "Tasa de peticiones HTTP (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
          "expr": "sum(rate(pos_http_requests_total[2m])) by (handler)",
          "legendFormat": "{{ handler }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1 }
        }
      }
    },
    {
      "id": 6,
      "title": "Errores HTTP 5xx (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
          "expr": "sum(rate(pos_http_requests_total{status=~\"5..\"}[2m])) by (handler)",
          "legendFormat": "{{ handler }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      }
    },
    {
      "id": 7,
      "title": "Latencia HTTP P50 / P95 / P99 (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(pos_http_request_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(pos_http_request_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(pos_http_request_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 8,
      "title": "Heap Node.js (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
          "expr": "nodejs_heap_size_used_bytes / 1024 / 1024",
          "legendFormat": "Heap usado"
        },
        {
          "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
          "expr": "nodejs_heap_size_total_bytes / 1024 / 1024",
          "legendFormat": "Heap total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 9,
      "title": "Event Loop Lag (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
          "expr": "nodejs_eventloop_lag_seconds * 1000",
          "legendFormat": "Lag (ms)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Conexiones PostgreSQL",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 24, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
          "expr": "pg_stat_activity_count",
          "legendFormat": "{{ state }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 11,
      "title": "Tamaño de la base de datos",
      "type": "stat",
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pos-prometheus" },
          "expr": "pg_database_size_bytes{datname=\"pos_db\"}",
          "legendFormat": "pos_db"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decbytes" } }
    }
  ],
  "templating": { "list": [] }
}
