{
  "name": "pos-saas",
  "version": "0.1.0",
  "private": true,
  "description": "POS SaaS for small food businesses",
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev": "pnpm --filter @pos/shared build && pnpm run dev:backend & pnpm run dev:frontend",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "build":          "pnpm run build:backend && pnpm run build:frontend",
    "test:backend":   "pnpm --filter backend test",
    "test:frontend":  "pnpm --filter frontend test:run",
    "test:e2e":       "playwright test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@prisma/client",
      "prisma"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
