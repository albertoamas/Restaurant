# ── GitHub Container Registry ─────────────────────────────────────────────────
# Format: owner/repo (all lowercase). E.g.: mycompany/pos-saas
GITHUB_REPOSITORY=albertoamas/restaurant

# Docker image tag to deploy (set automatically by CI via commit SHA)
IMAGE_TAG=latest

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=pos_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=pos_db

# ── Backend ───────────────────────────────────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_char_hex_string
JWT_EXPIRATION=24h

# ── Frontend / CORS ───────────────────────────────────────────────────────────
# Your server's public URL (no trailing slash)
FRONTEND_URL=https://YOUR_DOMAIN

# ── Admin panel ───────────────────────────────────────────────────────────────
# Secret key to access the /admin panel — keep this private
ADMIN_SECRET=CHANGE_ME_admin_secret_key

# ── Grafana (local — VPS puerto 3001) ─────────────────────────────────────────
# Accesible via SSH tunnel: ssh -L 3001:localhost:3001 root@<VPS_IP> -N
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# ── Grafana Cloud (GitHub Actions secrets — NO van en este archivo) ────────────
# Estas tres variables se configuran como GitHub Actions Secrets, no en el .env del VPS.
# El CD pipeline las inyecta en prometheus/prometheus.yml antes de cada deploy.
# Obtenerlas en: grafana.com → tu stack → Connections → Add new connection → Prometheus
#
# GRAFANA_CLOUD_REMOTE_WRITE_URL   → URL de remote_write (https://prometheus-prod-XX.grafana.net/api/prom/push)
# GRAFANA_CLOUD_INSTANCE_ID        → Número de instancia (e.g. 123456)
# GRAFANA_CLOUD_API_KEY            → API key generada en Grafana Cloud
#
# Si NO se configuran estos secrets, el pipeline sigue funcionando normalmente
# (Prometheus local sigue corriendo, solo no reenvía métricas a la nube).

# ── Timezone ───────────────────────────────────────────────────────────────────
# Sistema desplegado para Bolivia (UTC-4, sin horario de verano)
TZ=America/La_Paz
