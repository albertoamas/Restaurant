# ── GitHub Container Registry ─────────────────────────────────────────────────
# Format: owner/repo (all lowercase). E.g.: mycompany/pos-saas
GITHUB_REPOSITORY=albertoamas/restaurant

# Docker image tag to deploy (set automatically by CI via commit SHA)
IMAGE_TAG=latest

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=pos_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=pos_db

# ── Backend ───────────────────────────────────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_char_hex_string
JWT_EXPIRATION=24h

# ── Frontend / CORS ───────────────────────────────────────────────────────────
# Your server's public URL (no trailing slash)
FRONTEND_URL=http://YOUR_SERVER_IP_OR_DOMAIN

# ── Admin panel ───────────────────────────────────────────────────────────────
# Secret key to access the /admin panel — keep this private
ADMIN_SECRET=CHANGE_ME_admin_secret_key
