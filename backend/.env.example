# ── Database ─────────────────────────────────────────────────────────────────
# In Docker Compose production the host is the service name "postgres"
# In local dev use: postgresql://pos_user:pos_password@localhost:5433/pos_db
DATABASE_URL=postgresql://pos_user:CHANGE_ME@postgres:5432/pos_db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_char_hex_string
JWT_EXPIRATION=24h

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Public URL of your frontend (no trailing slash)
FRONTEND_URL=https://yourdomain.com

# ── Admin panel ───────────────────────────────────────────────────────────────
# Secret key to access the /admin panel — keep this private
ADMIN_SECRET=CHANGE_ME_admin_secret_key

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
