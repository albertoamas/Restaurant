# ── Backend env example (local development defaults) ─────────────────────────
# Copy this file to backend/.env and adjust values as needed.
# For production use the root template: .env.production.example

# ── Database (local) ──────────────────────────────────────────────────────────
# Default local PostgreSQL from docker-compose.yml
DATABASE_URL=postgresql://pos_user:pos_password@localhost:5433/pos_db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRATION=24h

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── CORS (local frontend) ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Admin panel ───────────────────────────────────────────────────────────────
ADMIN_SECRET=dev-admin-secret

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
